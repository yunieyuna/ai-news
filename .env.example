# --- LLM: Ollama (local, free) — no key needed if using default localhost ---
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Optional: paid/cloud APIs ---
# OPENAI_API_KEY=
# GROQ_API_KEY=

# --- Notify: email (free with Gmail app password) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password
# NOTIFY_EMAIL_TO=your@gmail.com

# --- Paths (defaults work if you run from project root) ---
# DATA_DIR=./data
